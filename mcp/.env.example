# ai-workspace secrets 範本
# 複製這份為 ~/.mcp.env（放使用者家目錄，不放在 ai-workspace 目錄內），填入真實值
# ~/.mcp.env 不進 Git，各主機手動填值（同帳號沿用同一組 key）
# Shell 需 `source ~/.mcp.env` 才能讓 ${GITLAB_TOKEN} 這類引用生效

# ── 工作 ──────────────────────────────
GITLAB_TOKEN=

# ── 個人 Google ────────────────────────
GOOGLE_PERSONAL_CREDENTIALS=

# ── 其他 MCP 服務（依需求新增）──────────
# MY_SERVICE_TOKEN=
